# ServEasy — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs

# ── SMTP (email) ──────────────────────────────
# Option 1 : Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votreadresse@gmail.com
SMTP_PASS=votre_mot_de_passe_application

# Option 2 : Brevo (ex Sendinblue) — recommandé pour Cameroun
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=votre_login_brevo
# SMTP_PASS=votre_cle_brevo

# ── Serveur ───────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
